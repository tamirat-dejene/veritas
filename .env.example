# ==============================================================================
# Global Service Configuration
# ==============================================================================
SYSTEM_MODE=development
GO_PORT=8080
PY_PORT=8000

# ==============================================================================
# Service URLs
# ==============================================================================
AUTH_SERVICE_URL=http://auth-service:8080
ENTERPRISE_SERVICE_URL=http://enterprise-service:8080
PAYMENT_SERVICE_URL=http://payment-service:8080
EXAM_SERVICE_URL=http://exam-service:8080
CANDIDATE_SERVICE_URL=http://candidate-service:8080
PROCTORING_SERVICE_URL=http://proctoring-service:8000
FACE_VERIFICATION_SERVICE_URL=http://face-verification-service:8000
GRADING_SERVICE_URL=http://grading-service:8000
REPORTING_SERVICE_URL=http://reporting-service:8000

# ==============================================================================
# Database Configuration (PostgreSQL)
# ==============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_VERITAS_CORE_DB=veritas_core

# ==============================================================================
# PGAdmin Configuration
# ==============================================================================
PGADMIN_DEFAULT_EMAIL=pgadmin4@pgadmin.org
PGADMIN_DEFAULT_PASSWORD=pgadmin

# ==============================================================================
# Cache & Message Broker (Redis)
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
KAFKA_BROKERS=kafka:9092,another-kafka:9093

# ==============================================================================
# Security
# ==============================================================================
# JWT Secret Key (Change this in production!)
JWT_SECRET=your-super-secret-key-here
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
ENROLLMENT_TOKEN_SECRET=super-secret-enrollment-key

# ==============================================================================
# CORS Configuration
# ==============================================================================
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID

# ==============================================================================
# Logging
# ==============================================================================
# Options: console | pretty
LOG_FORMAT=console 
LOG_LEVEL=debug
# Options: compact, detailed, minimal
LOG_STYLE=compact

# ==============================================================================
# Stripe
# ==============================================================================
# Example: sk_test_4eC39HqLyjWDarjtT1zdp7dc
STRIPE_SECRET_KEY=sk_test_example_secret_key
# Example: whsec_1234567890abcdef
STRIPE_WEBHOOK_SECRET=whsec_example_webhook_secret
# Example: https://veritas.com/payment/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_SUCCESS_URL=https://veritas.com/payment/success?session_id={CHECKOUT_SESSION_ID}
# Example: https://veritas.com/payment/cancel
STRIPE_CANCEL_URL=https://veritas.com/payment/cancel